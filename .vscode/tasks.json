      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "VC707: Vivado setup project",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/run_vivado_vc707.ps1",
        "-Action",
        "setup"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
