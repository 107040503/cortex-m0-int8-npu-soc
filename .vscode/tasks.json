      ],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Report: check coverage tools",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/check_coverage_tools.ps1"
